rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Wskaźnik użytkownika -> rodzina. Czyta/zapisuje tylko właściciel konta.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rodzina = jedno dziecko współdzielone przez rodziców (pole members[]).
    match /families/{familyId} {

      // Czytać i edytować mogą tylko członkowie rodziny.
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;

      // Tworzyć może każdy zalogowany, o ile dodaje SIEBIE jako członka.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      // Aktualizacja: członek może zmieniać dane;
      // NOWY rodzic może DOŁĄCZYĆ — dopisać wyłącznie własny uid do members.
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (
          request.auth.uid in request.resource.data.members
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        )
      );

      // Usuwać rodzinę może tylko właściciel.
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.owner;

      // Karmienia – dostęp dla członków rodziny.
      match /feedings/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }

      // Sen – dostęp dla członków rodziny.
      match /sleeps/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }
    }

    // Wszystko inne domyślnie zablokowane.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
